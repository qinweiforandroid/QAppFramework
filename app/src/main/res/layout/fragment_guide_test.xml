<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <Button
        android:id="@+id/btnGuideTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="顶部引导" />

    <Button
        android:id="@+id/btnGuideBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="底部引导" />

    <Button
        android:id="@+id/btnGuideLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="左侧引导" />

    <Button
        android:id="@+id/btnGuideRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="右侧引导" />

    <Button
        android:id="@+id/btnGuideTarget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TargetView"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flowGuideButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="btnGuideTop,btnGuideBottom,btnGuideLeft,btnGuideRight"
        app:flow_horizontalGap="12dp"
        app:flow_verticalGap="12dp"
        app:flow_wrapMode="chain"
        app:flow_horizontalStyle="packed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
